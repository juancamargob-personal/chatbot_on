# ---------------------------------------------------------------------------
# Post-checks
# ---------------------------------------------------------------------------

def run_post_checks() -> bool:
    """Run post-execution validation. Returns True if all pass."""
    log("Running post-checks...", "INFO")
    all_ok = True
{% for check in validation.post_checks %}
{% if check.type.value == "pods_running" %}

    # Check: pods running in namespace '{{ check.namespace }}'
    result = kubectl("get pods -n {{ check.namespace }} -l {{ check.label_selector }} --no-headers", check=False, capture=True)
    if result.returncode != 0:
        log("Could not check pods in '{{ check.namespace }}'", "ERROR")
        all_ok = False
    else:
        running = [l for l in result.stdout.strip().split("\n") if "Running" in l]
        log(f"Pods running in '{{ check.namespace }}': {len(running)}{% if check.expected_count %} (expected: {{ check.expected_count }}){% endif %}", "INFO")
{% elif check.type.value == "service_available" %}

    # Check: service '{{ check.service_name }}' exists in '{{ check.namespace }}'
    result = kubectl("get svc {{ check.service_name }} -n {{ check.namespace }}", check=False, capture=True)
    if result.returncode != 0:
        log("Service '{{ check.service_name }}' not found", "ERROR")
        all_ok = False
    else:
        log("Service '{{ check.service_name }}' is available", "OK")
{% endif %}
{% endfor %}
{% if not validation.post_checks %}
    log("No post-checks defined", "WARN")
{% endif %}

    return all_ok


