# ---------------------------------------------------------------------------
# Pre-checks
# ---------------------------------------------------------------------------

def run_pre_checks() -> bool:
    """Run pre-execution validation checks. Returns True if all pass."""
    log("Running pre-checks...", "INFO")
    all_ok = True
{% for check in validation.pre_checks %}
{% if check.type.value == "cluster_reachable" %}

    # Check: cluster reachable{% if check.target %} ({{ check.target }}){% endif %}

    try:
        result = kubectl("cluster-info", check=False, capture=True)
        if result.returncode != 0:
            log("Cluster is not reachable", "ERROR")
            all_ok = False
        else:
            log("Cluster is reachable", "OK")
    except FileNotFoundError:
        log("kubectl not found in PATH", "ERROR")
        all_ok = False
{% elif check.type.value == "namespace_available" %}

    # Check: namespace '{{ check.namespace }}' does not already exist
    result = kubectl("get namespace {{ check.namespace }}", check=False, capture=True)
    if result.returncode == 0:
        log("Namespace '{{ check.namespace }}' already exists", "WARN")
    else:
        log("Namespace '{{ check.namespace }}' is available", "OK")
{% elif check.type.value == "namespace_exists" %}

    # Check: namespace '{{ check.namespace }}' exists
    result = kubectl("get namespace {{ check.namespace }}", check=False, capture=True)
    if result.returncode != 0:
        log("Namespace '{{ check.namespace }}' does not exist", "ERROR")
        all_ok = False
    else:
        log("Namespace '{{ check.namespace }}' exists", "OK")
{% elif check.type.value == "helm_repo_available" %}

    # Check: Helm repo is accessible
    log("Checking Helm repo: {{ check.target }}", "INFO")
    # Helm repos are added during execution; skip deep check here
    log("Helm repo check deferred to execution", "OK")
{% endif %}
{% endfor %}
{% if not validation.pre_checks %}
    log("No pre-checks defined", "WARN")
{% endif %}

    return all_ok


