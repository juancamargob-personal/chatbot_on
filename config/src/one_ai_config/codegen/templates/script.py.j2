# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def log(msg: str, level: str = "INFO") -> None:
    """Print a timestamped log message."""
    ts = time.strftime("%H:%M:%S")
    prefix = {"INFO": "ℹ️", "OK": "✅", "WARN": "⚠️", "ERROR": "❌", "RUN": "▶️"}
    print(f"[{ts}] {prefix.get(level, 'ℹ️')}  {msg}")


def run_cmd(cmd: list[str], check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    """Run a shell command with logging."""
    cmd_str = " ".join(cmd)
    if DRY_RUN:
        log(f"[DRY RUN] Would execute: {cmd_str}", "RUN")
        return subprocess.CompletedProcess(cmd, 0, stdout="", stderr="")
    log(f"Executing: {cmd_str}", "RUN")
    return subprocess.run(cmd, check=check, capture_output=capture, text=True)


def kubectl(args: str, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    """Run a kubectl command."""
    cmd = ["kubectl"]
    if KUBECONFIG_PATH:
        cmd.extend(["--kubeconfig", KUBECONFIG_PATH])
    cmd.extend(args.split())
    return run_cmd(cmd, check=check, capture=capture)


def helm(args: str, check: bool = True, capture: bool = False) -> subprocess.CompletedProcess:
    """Run a helm command."""
    cmd = ["helm"]
    if KUBECONFIG_PATH:
        cmd.extend(["--kubeconfig", KUBECONFIG_PATH])
    cmd.extend(args.split())
    return run_cmd(cmd, check=check, capture=capture)


