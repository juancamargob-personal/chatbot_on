# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description="{{ metadata.description }}")
    parser.add_argument("--dry-run", action="store_true", help="Show what would be executed without running anything")
    parser.add_argument("--skip-pre-checks", action="store_true", help="Skip pre-execution checks")
    parser.add_argument("--kubeconfig", default=None, help="Path to kubeconfig file")
    parser.add_argument("--one-endpoint", default=None, help="OpenNebula XML-RPC endpoint")
    parser.add_argument("--one-session", default=None, help="OpenNebula session string (user:pass)")
    args = parser.parse_args()

    global DRY_RUN, KUBECONFIG_PATH, OPENNEBULA_ENDPOINT, OPENNEBULA_SESSION
    DRY_RUN = args.dry_run
    if args.kubeconfig:
        KUBECONFIG_PATH = args.kubeconfig
    if args.one_endpoint:
        OPENNEBULA_ENDPOINT = args.one_endpoint
    if args.one_session:
        OPENNEBULA_SESSION = args.one_session

    log("=" * 60, "INFO")
    log("{{ metadata.description }}", "INFO")
    log("Risk level: {{ metadata.risk_level }}", "INFO")
    if DRY_RUN:
        log("DRY RUN MODE — no changes will be made", "WARN")
    log("=" * 60, "INFO")

    # Pre-checks
    if not args.skip_pre_checks:
        if not run_pre_checks():
            log("Pre-checks failed. Aborting.", "ERROR")
            sys.exit(1)

    # Execute steps
    try:
{% for step in steps %}
        {{ step.id }}()
{% endfor %}
    except Exception as e:
        log(f"Execution failed: {e}", "ERROR")
{% if rollback.steps %}
        run_rollback()
{% endif %}
        sys.exit(1)

    # Post-checks
    if not run_post_checks():
        log("Post-checks failed.", "WARN")

    log("All steps completed successfully!", "OK")


if __name__ == "__main__":
    main()
